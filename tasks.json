{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Auto-Push Loop",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "while ($true) { git add .; git commit -m 'Auto-update'; git push origin main; Start-Sleep -Seconds 30 }"
            ],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            }
        }
    ]
}
